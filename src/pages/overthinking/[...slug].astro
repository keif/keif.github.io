---
import { type CollectionEntry, getCollection } from "astro:content"
import OverthinkingDetails from "@/layouts/OverthinkingDetails.astro"

export interface Props {
    post: CollectionEntry<"overthinking">
}

export async function getStaticPaths() {
    const entries = await getCollection("overthinking", ({ data }) => !data.draft)
    return entries.map((post) => ({
        params: { slug: post.id },
        props: { post },
    }))
}

const { post } = Astro.props
---

<OverthinkingDetails post={post} />
