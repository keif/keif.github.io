---
import { getCollection } from "astro:content"
import Layout from "@/layouts/Layout.astro"
import Header from "@/components/Header.astro"
import Footer from "@/components/Footer.astro"
import MeetupCard from "@/components/MeetupCard.astro"
import Hr from "@/components/Hr.astro"

const allMeetups = await getCollection("meetups")

// Filter out drafts and sort by location, then by title
const meetups = allMeetups
  .filter(({ data }) => !data.draft)
  .sort((a, b) => {
    // First sort by location
    const locationCompare = a.data.location.localeCompare(b.data.location)
    if (locationCompare !== 0) return locationCompare
    // Then sort by title within same location
    return a.data.title.localeCompare(b.data.title)
  })

// Group meetups by location for stats
const meetupsByLocation = meetups.reduce((acc, meetup) => {
  const location = meetup.data.location
  acc[location] = (acc[location] || 0) + 1
  return acc
}, {} as Record<string, number>)

const activeMeetups = meetups.filter(({ data }) => data.active)
const totalMeetups = meetups.length

// Extract unique locations and tags for filters
const uniqueLocations = Array.from(new Set(meetups.map(m => m.data.location))).sort()
const allTags = meetups.flatMap(m => m.data.tags)
const uniqueTags = Array.from(new Set(allTags)).sort()
---

<Layout
  title="Tech Meetups"
  description="A curated collection of tech meetups across Ohio, focusing on Cleveland and Columbus communities."
>
  <Header activeNav="meetups" />
  <main id="main-content" class="mx-auto max-w-screen-xl px-4 md:px-8">
    <section class="pt-12 pb-8">
      <h1 class="text-4xl font-bold sm:text-5xl prose-headings mb-4">Tech Meetups</h1>
      <p class="text-lg text-muted-foreground max-w-3xl leading-relaxed mb-6">
        A curated collection of tech meetups across Ohio. These communities bring together
        developers, designers, and tech enthusiasts for learning, collaboration, and networking.
      </p>

      <div class="bg-muted/50 border border-border rounded-lg p-4 mb-4 max-w-3xl">
        <p class="text-sm text-muted-foreground mb-2">
          <strong class="text-foreground">Attribution:</strong> This collection is based on excellent
          work by:
        </p>
        <ul class="text-sm text-muted-foreground space-y-1 ml-4">
          <li>
            <a
              href="https://sadukie.com/2026/01/19/cleveland-tech-is-not-dead.html"
              target="_blank"
              rel="noopener noreferrer"
              class="text-accent hover:underline"
            >
              Sadie Rae's Cleveland Tech Communities Guide
            </a>
          </li>
          <li>
            <a
              href="https://kylfrost.com/columbus-meetups/"
              target="_blank"
              rel="noopener noreferrer"
              class="text-accent hover:underline"
            >
              Kyle Frost's Columbus Meetups Directory
            </a>
          </li>
        </ul>
        <p class="text-xs text-muted-foreground mt-3">
          Please visit their pages for the most comprehensive and up-to-date information.
        </p>
      </div>

      <div class="flex flex-wrap gap-3 text-sm text-muted-foreground">
        <span>
          <strong class="text-foreground">{totalMeetups}</strong> meetups
        </span>
        <span>•</span>
        <span>
          <strong class="text-foreground">{activeMeetups.length}</strong> active
        </span>
        {
          Object.entries(meetupsByLocation).map(([location, count]) => (
            <>
              <span>•</span>
              <span>
                <strong class="text-foreground">{count}</strong> in {location}
              </span>
            </>
          ))
        }
      </div>
    </section>

    <Hr />

    {
      meetups.length > 0 ? (
        <section class="pt-8 pb-16">
          <div class="mb-8 space-y-4">
            <div class="flex flex-col sm:flex-row gap-4">
              <div class="flex-1">
                <label for="location-filter" class="block text-sm font-medium text-foreground mb-2">
                  Filter by Location
                </label>
                <select
                  id="location-filter"
                  class="w-full px-4 py-2 bg-background border border-border rounded-lg text-foreground focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent"
                >
                  <option value="">All Locations</option>
                  {uniqueLocations.map((location) => (
                    <option value={location}>{location}</option>
                  ))}
                </select>
              </div>
              <div class="flex-1">
                <label for="tag-filter" class="block text-sm font-medium text-foreground mb-2">
                  Filter by Topic
                </label>
                <select
                  id="tag-filter"
                  class="w-full px-4 py-2 bg-background border border-border rounded-lg text-foreground focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent"
                >
                  <option value="">All Topics</option>
                  {uniqueTags.map((tag) => (
                    <option value={tag}>{tag}</option>
                  ))}
                </select>
              </div>
            </div>
            <div class="flex items-center justify-between">
              <p id="filter-count" class="text-sm text-muted-foreground">
                Showing <span id="visible-count">{meetups.length}</span> of {meetups.length} meetups
              </p>
              <button
                id="clear-filters"
                class="text-sm text-accent hover:underline focus:outline-none focus:ring-2 focus:ring-accent rounded px-2 py-1"
              >
                Clear filters
              </button>
            </div>
          </div>
          <div id="meetups-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {meetups.map((meetup) => (
              <div
                class="meetup-card"
                data-location={meetup.data.location}
                data-tags={meetup.data.tags.join(',')}
              >
                <MeetupCard {...meetup} />
              </div>
            ))}
          </div>
          <p id="no-results" class="text-muted-foreground text-center mt-8 hidden">
            No meetups match your filters. Try adjusting your selections.
          </p>
        </section>
      ) : (
        <section class="pt-12 pb-16">
          <p class="text-muted-foreground text-center">No meetups yet. Check back soon!</p>
        </section>
      )
    }
  </main>
  <Footer />
</Layout>

<script>
  function initFilters() {
    const locationFilter = document.getElementById('location-filter') as HTMLSelectElement | null
    const tagFilter = document.getElementById('tag-filter') as HTMLSelectElement | null
    const clearButton = document.getElementById('clear-filters') as HTMLButtonElement | null
    const meetupCards = document.querySelectorAll('.meetup-card') as NodeListOf<HTMLElement>
    const visibleCount = document.getElementById('visible-count')
    const noResults = document.getElementById('no-results')

    if (!locationFilter || !tagFilter || !clearButton || !visibleCount || !noResults) return

    function filterMeetups() {
      if (!locationFilter || !tagFilter || !visibleCount || !noResults) return

      const selectedLocation = locationFilter.value.toLowerCase()
      const selectedTag = tagFilter.value.toLowerCase()
      let visibleCards = 0

      meetupCards.forEach((card) => {
        const cardLocation = (card.dataset.location || '').toLowerCase()
        const cardTags = (card.dataset.tags || '').toLowerCase().split(',')

        const locationMatch = !selectedLocation || cardLocation === selectedLocation
        const tagMatch = !selectedTag || cardTags.includes(selectedTag)

        if (locationMatch && tagMatch) {
          card.style.display = ''
          visibleCards++
        } else {
          card.style.display = 'none'
        }
      })

      visibleCount.textContent = visibleCards.toString()

      if (visibleCards === 0) {
        noResults.classList.remove('hidden')
      } else {
        noResults.classList.add('hidden')
      }
    }

    function clearFilters() {
      if (!locationFilter || !tagFilter) return

      locationFilter.value = ''
      tagFilter.value = ''
      filterMeetups()
    }

    locationFilter.addEventListener('change', filterMeetups)
    tagFilter.addEventListener('change', filterMeetups)
    clearButton.addEventListener('click', clearFilters)
  }

  initFilters()

  // Re-initialize filters on view transitions navigation
  document.addEventListener('astro:after-swap', initFilters)
</script>
