---
import { getCollection } from "astro:content";
import getUniqueTags from "@/utils/getUniqueTags";

export interface Props {
    activeTag?: string;
}

const { activeTag } = Astro.props;

// Slugs whose canonical /tags/<slug>/ route is overwritten by a case-variant
// legacyTagMap alias during getStaticPaths generation, leaving the page as a
// redirect-to-self loop. Derived from src/pages/tags/[tag]/[...page].astro
// legacyTagMap entries where key.toLowerCase() === value. Re-derive when those
// entries change.
const BROKEN_CANONICAL_SLUGS = new Set([
    "accessibility",
    "api",
    "astro",
    "cli",
    "design",
    "docker",
    "go",
    "hosting",
    "infrastructure",
    "logging",
    "migration",
    "python",
    "react",
    "shell",
    "ux",
    "vite",
]);

const posts = await getCollection("blog", ({ data }) => !data.draft);
const safeTags = getUniqueTags(posts).filter(({ tag }) => !BROKEN_CANONICAL_SLUGS.has(tag));
const topTags = safeTags
    .slice()
    .sort((a, b) => b.count - a.count || a.tag.localeCompare(b.tag))
    .slice(0, 8);

// Ensure the active tag is always visible as a chip so the activeTag highlight
// reflects "you are here" even on long-tail tag pages where the current tag
// isn't in the top-8 by post count.
if (activeTag && !topTags.some((t) => t.tag === activeTag)) {
    const activeEntry = safeTags.find((t) => t.tag === activeTag);
    if (activeEntry) topTags.push(activeEntry);
}
---

<nav aria-label="Browse posts by tag" class="my-4">
    <ul class="flex flex-wrap gap-2 p-0 list-none">
        {
            topTags.map(({ tag, tagName }) => (
                <li>
                    <a
                        href={`/tags/${tag}/`}
                        class:list={[
                            "inline-flex items-center rounded-full border border-border px-3 py-1 text-sm transition-colors hover:bg-accent hover:text-background",
                            { "active-nav": activeTag === tag },
                        ]}
                    >
                        {tagName}
                    </a>
                </li>
            ))
        }
    </ul>
</nav>
